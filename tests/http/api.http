### 创建工作流 (start -> mcp_tool -> end)
POST http://localhost:8080/api/v1/workflows
Content-Type: application/json

{
  "name": "test-flow",
  "description": "测试工作流: start -> mcp_tool -> end",
  "nodes": [
    {
      "id": "n1",
      "type": "start",
      "name": "开始",
      "config": {},
      "position": {"x": 0, "y": 0}
    },
    {
      "id": "n2",
      "type": "mcp_tool",
      "name": "调用MCP工具",
      "config": {
        "mcp_tool": {
          "server_url": "http://localhost:3000",
          "tool_name": "search",
          "arguments": {"query": "hello"}
        }
      },
      "position": {"x": 200, "y": 0}
    },
    {
      "id": "n3",
      "type": "end",
      "name": "结束",
      "config": {},
      "position": {"x": 400, "y": 0}
    }
  ],
  "edges": [
    {"id": "e1", "source": "n1", "target": "n2"},
    {"id": "e2", "source": "n2", "target": "n3"}
  ]
}

### 获取工作流列表
GET http://localhost:8080/api/v1/workflows?page=1&page_size=20

### 获取工作流详情
GET http://localhost:8080/api/v1/workflows/1

### 更新工作流
PUT http://localhost:8080/api/v1/workflows/1
Content-Type: application/json

{
  "name": "test-flow-updated",
  "description": "更新后的测试工作流",
  "nodes": [
    {
      "id": "n1",
      "type": "start",
      "name": "开始",
      "config": {},
      "position": {"x": 0, "y": 0}
    },
    {
      "id": "n2",
      "type": "llm",
      "name": "调用LLM",
      "config": {
        "llm": {
          "provider": "openai",
          "model": "gpt-4",
          "prompt": "你好",
          "temperature": 0.7,
          "max_tokens": 1000
        }
      },
      "position": {"x": 200, "y": 0}
    },
    {
      "id": "n3",
      "type": "end",
      "name": "结束",
      "config": {},
      "position": {"x": 400, "y": 0}
    }
  ],
  "edges": [
    {"id": "e1", "source": "n1", "target": "n2"},
    {"id": "e2", "source": "n2", "target": "n3"}
  ]
}

### 执行工作流
POST http://localhost:8080/api/v1/workflows/1/execute
Content-Type: application/json

{
  "query": "hello world"
}

### 获取执行详情
GET http://localhost:8080/api/v1/executions/1

### 删除工作流
DELETE http://localhost:8080/api/v1/workflows/1
